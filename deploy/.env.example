# UMAI Platform customer configuration
# Copy this file to .env and fill in every required value before startup.

# Image version
# Pin to a specific release tag (for example 1.2.0) or use "latest".
UMAI_VERSION=latest

# License
# REQUIRED. Provided by UMAI after purchase.
UMAI_LICENSE_KEY=

# REQUIRED. Ed25519 public key used to verify the signed license token.
# Provided by UMAI with your license pack. Paste the PEM block as a single value.
UMAI_LICENSE_PUBLIC_KEY=

# Fail startup if the license token cannot be verified.
UMAI_LICENSE_STRICT=true

# REQUIRED. Your organization UUID - provided in your welcome email.
UMAI_ORGANIZATION_ID=

# Your organization display name shown in the UI.
UMAI_ORGANIZATION_NAME=My Company

# Plan tier - do not change unless instructed by UMAI support.
UMAI_ORGANIZATION_PLAN=enterprise

# REQUIRED. License expiry date from your license document (ISO 8601).
UMAI_LICENSE_EXPIRES_AT=2026-12-31T23:59:59Z

# UMAI Service
# REQUIRED. Random secret used to sign internal service tokens.
# Generate with: openssl rand -hex 32
UMAI_SERVICE_SECRET_KEY=

# REQUIRED. PostgreSQL connection string for umai-service.
UMAI_DATABASE_URL=postgresql://umai:password@db:5432/umai

# Allowed CORS origins (comma-separated). Include your control-center URL.
UMAI_CORS_ORIGINS=http://localhost:3000

# Internal Redis used for published guardrail snapshots.
# Leave the default unless you are pointing the stack at an external Redis.
UMAI_REDIS_URL=redis://redis:6379/0

# REQUIRED. Shared HMAC-SHA256 secret for published guardrail snapshot signatures.
# Must be identical in umai-service (signer) and umai-engine (verifier).
# Generate with: openssl rand -hex 32
UMAI_SNAPSHOT_SIGNING_KEY=

# Optional key identifier stored with signed snapshots.
UMAI_SNAPSHOT_SIGNING_KEY_ID=default

# Runtime mode and admin trust boundary.
# Keep network-trust only when umai-service is not exposed directly to untrusted networks.
UMAI_ENVIRONMENT=production
UMAI_ADMIN_AUTH_MODE=network-trust

# Guardrail runtime profile used for context-aware policies.
# The selected secret env must also be passed to umai-engine.
UMAI_DEFAULT_GUARDRAIL_LLM_PROVIDER=OPENROUTER
UMAI_DEFAULT_GUARDRAIL_LLM_BASE_URL=https://openrouter.ai/api/v1
UMAI_DEFAULT_GUARDRAIL_LLM_MODEL=openai/gpt-oss-safeguard-20b
UMAI_DEFAULT_GUARDRAIL_LLM_TIMEOUT_MS=2000
UMAI_DEFAULT_GUARDRAIL_LLM_AUTH_TYPE=bearer
UMAI_DEFAULT_GUARDRAIL_LLM_AUTH_SECRET_ENV=OPENROUTER_API_KEY
UMAI_DEFAULT_GUARDRAIL_LLM_AUTH_HEADER_NAME=
LLM_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
GROQ_API_KEY=
HF_TOKEN=

# Optional idempotent bootstrap. Enable this on a PoC/customer VM when you want
# the tenant, environment, project, and built-in guardrail published at startup.
UMAI_RUN_SEED=false
UMAI_SEED_TENANT_ID=
UMAI_SEED_TENANT_NAME=
UMAI_SEED_LICENSE_DAYS=3650
UMAI_SEED_LICENSE_PLAN=enterprise
UMAI_SEED_ALLOW_LLM_CALLS=true
UMAI_SEED_ENVIRONMENT_ID=prod
UMAI_SEED_ENVIRONMENT_NAME=Production
UMAI_SEED_PROJECT_ID=poc
UMAI_SEED_PROJECT_NAME=PoC
UMAI_SEED_GUARDRAIL_TEMPLATE_ID=
UMAI_SEED_GUARDRAIL_ID=
UMAI_SEED_GUARDRAIL_NAME=
UMAI_SEED_PUBLISH_GUARDRAIL=true

# Control Center - Session
# REQUIRED. Random secret for signing session JWTs.
# Generate with: openssl rand -hex 32
CC_SESSION_SECRET=

# Session lifetime in seconds (default: 12 hours).
CC_SESSION_TTL_SECONDS=43200

# Host port the control center UI is served on.
CC_HOST_PORT=3000

# REQUIRED. Random secret for signing browser extension device tokens.
# Generate with: openssl rand -hex 32
CC_EXTENSION_JWT_SECRET=

# Control Center - LDAP / Active Directory
# REQUIRED. LDAP server URL (ldap:// or ldaps://).
LDAP_URL=ldap://your-ldap-server:389

# REQUIRED. Service account DN used to search the directory.
LDAP_BIND_DN=cn=svc-umai,ou=ServiceAccounts,dc=corp,dc=example,dc=com

# REQUIRED. Password for the service account above.
LDAP_BIND_PASSWORD=

# REQUIRED. Base DN to search for users.
LDAP_USER_SEARCH_BASE=ou=Users,dc=corp,dc=example,dc=com

# Attribute containing the login username (default: sAMAccountName).
LDAP_USERNAME_ATTRIBUTE=sAMAccountName

# Attribute containing the user's display name (default: displayName).
LDAP_DISPLAY_NAME_ATTRIBUTE=displayName

# Attribute containing the user's email (default: mail).
LDAP_EMAIL_ATTRIBUTE=mail

# Comma-separated list of groups allowed to log in (empty = all users).
LDAP_ALLOWED_GROUPS=

# LDAP connection/search timeouts in milliseconds.
LDAP_TIMEOUT_MS=10000
LDAP_CONNECT_TIMEOUT_MS=10000

# Set to true only if your LDAPS certificate is self-signed (not recommended in prod).
LDAP_INSECURE_SKIP_VERIFY=false
